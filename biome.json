{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/next",
    "ultracite/biome/react"
  ],
  "linter": {
    "rules": {
      "a11y": {
        "useValidAnchor": "off"
      },
      "performance": {
        "noBarrelFile": "off",
        "noImgElement": "off"
      },
      "suspicious": {
        "noDuplicateCustomProperties": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["registry/react/examples/form/**"],
      "linter": {
        "rules": {
          "correctness": {
            "noChildrenProp": "off"
          },
          "performance": {
            "noNamespaceImport": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off",
            "noEmptyBlockStatements": "off",
            "useAwait": "off"
          }
        }
      }
    },
    {
      "includes": ["scripts/normalize-component-mdx-prop-unions.mts"],
      "linter": {
        "rules": {
          "performance": {
            "useTopLevelRegex": "off"
          }
        }
      }
    }
  ]
}
